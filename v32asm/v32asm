#!/usr/bin/env bash
###
### v32asm - attempt at a Vircon32 assembler written in bash; initially,
###          to assist in prototyping and testing some RegEx that I need
###          for v32sim's live assembly injection.
###
########################################################################################

########################################################################################
##
## Establish RegEx patterns for tokens
##
OPCODE='\<[A-Z][A-Z2]{1,4}\>'
INT_TWO_OPCODE="\<JT|JF|IEQ|INE|IGT|IGE|ILT|ILE|MOV|LEA|IN|OUT|AND|OR|XOR|SHL"
INT_TWO_OPCODE="${INT_TWO_OPCODE}|IADD|ISUB|IMUL|IDIV|IMOD|IMIN|IMAX"
FLOAT_TWO_OPCODE="\<FEQ|FNE|FGT|FGE|FLT|FLE|FADD"
FLOAT_TWO_OPCODE="${FLOAT_TWO_OPCODE}|FSUB|FMUL|FDIV|FMOD|FMIN|FMAX|ATAN2|POW\>"
REGISTER='\<R[0-9]|R1[0-5]\>'
HEX1='\<0[Xx][0-9A-F]{1,8}\>'
HEX2='\<[0-9A-F]{1,8}[Hh]\>'
OCT='\<0[0-7]+\>'
BIN='\<0[Bb][01]{1,32}\>'
DEC1='\<[0-9]|[1-9][0-9]*\>'
DEC2='\<#[0-9]|[1-9][0-9]*\>'
IMMEDIATE="${BIN}|${OCT}|${DEC1}|${DEC2}|${HEX1}|${HEX2}"
#INDEX="${REGISTER}[-+]${IMMEDIATE}"
INDEX="[-+]"
#DEREF="[[](${REGISTER}|${IMMEDIATE}|${INDEX})[]]"
DEREF="[[].*[]]"
OPERAND="(${DEREF}|${REGISTER}|${IMMEDIATE})"
#OPERAND="[[]?(${REGISTER}|${IMMEDIATE}|${REGISTER}${INDEX}${IMMEDIATE})[]]?"
ZERO_OPCODE='\<HLT|WAIT|RET|MOVS|SETS\>'
ONE_OPCODE="\<JMP|CALL|PUSH|POP|CMPS|CIF|CFI|CIB|CFB|NOT|BNOT|ISGN|IABS|FSGN|FABS"
ONE_OPCODE="${ONE_OPCODE}|FLR|CEIL|ROUND|SIN|ACOS|LOG\>"
ZEROOPER="[^;]*${ZERO_OPCODE}"
ONE_OPER="[^;]*${ONE_OPCODE} *${OPERAND}"
TWO_OPER="[^;]*${INT_TWO_OPCODE} *${OPERAND} *, *${OPERAND}"
declare -A OTYPE
OTYPE["index"]="${INDEX}"
OTYPE["deref"]="${DEREF}"
OTYPE["register"]="${REGISTER}"
OTYPE["immediate"]="${IMMEDIATE}"

declare -A ITYPE
ITYPE["hex"]="${HEX1}"
ITYPE["hex2"]="${HEX2}"
ITYPE["oct"]="${OCT}"
ITYPE["bin"]="${BIN}"
ITYPE["dec"]="${DEC1}"
ITYPE["dec2"]="${DEC2}"

declare -a PTYPE
PTYPE[0]="${ZERO_OPCODE}"
PTYPE[1]="${ONE_OPCODE}"
PTYPE[2]="${INT_TWO_OPCODE}"
PTYPE[3]="${FLOAT_TWO_OPCODE}"

declare -A opcode
opcode["HLT"]="00"
opcode["WAIT"]="01"
opcode["JMP"]="02"
opcode["CALL"]="03"
opcode["RET"]="04"
opcode["JT"]="05"
opcode["JF"]="06"
opcode["IEQ"]="07"
opcode["INE"]="08"
opcode["IGT"]="09"
opcode["IGE"]="0A"
opcode["ILT"]="0B"
opcode["ILE"]="0C"
opcode["FEQ"]="0D"
opcode["FNE"]="0E"
opcode["FGT"]="0F"
opcode["FGE"]="10"
opcode["FLT"]="11"
opcode["FLE"]="12"
opcode["MOV"]="13"
opcode["LEA"]="14"
opcode["PUSH"]="15"
opcode["POP"]="16"
opcode["IN"]="17"
opcode["OUT"]="18"
opcode["MOVS"]="19"
opcode["SETS"]="1A"
opcode["CMPS"]="1B"
opcode["CIF"]="1C"
opcode["CFI"]="1D"
opcode["CIB"]="1E"
opcode["CFB"]="1F"
opcode["NOT"]="20"
opcode["AND"]="21"
opcode["OR"]="22"
opcode["XOR"]="23"
opcode["BNOT"]="24"
opcode["SHL"]="25"
opcode["IADD"]="26"
opcode["ISUB"]="27"
opcode["IMUL"]="28"
opcode["IDIV"]="29"
opcode["IMOD"]="2A"
opcode["ISGN"]="2B"
opcode["IMIN"]="2C"
opcode["IMAX"]="2D"
opcode["IABS"]="2E"
opcode["FADD"]="2F"
opcode["FSUB"]="30"
opcode["FMUL"]="31"
opcode["FDIV"]="32"
opcode["FMOD"]="33"
opcode["FSGN"]="34"
opcode["FMIN"]="35"
opcode["FMAX"]="36"
opcode["FABS"]="37"
opcode["FLR"]="38"
opcode["CEIL"]="39"
opcode["ROUND"]="3A"
opcode["SIN"]="3B"
opcode["ACOS"]="3C"
opcode["ATAN2"]="3D"
opcode["LOG"]="3E"
opcode["POW"]="3F"
IMM_TALLY=0
imm_flag=0

function parse_reg()
{
    token="${1}"
	the_reg=$(echo "${token}" | egrep -o "${REGISTER}")
    echo "${the_reg}"
}

########################################################################################
##
## parse_imm(): function to parse and convert immediate value to standard hex
##              representation, leading '0x', and 8 total digits. It converts
##              a number of recognized formats:
##
##              0bXXXX - binary value (1-32 bits)
##              0XXXX  - octal value
##              XXXX   - decimal value
##              #XXXX  - decimal value
##              0xXXXX - standard hexadecimal representation (the target)
##              XXXXH  - alternate hexadecimal representation
##
function parse_imm()
{
    token="${1}"
    for attr in bin oct dec1 dec2 hex2; do
        d_imm=$(echo "${token}"  | egrep -o "${ITYPE[${attr}]}")
        t_imm=$(echo "${token}"  | egrep -o "${ITYPE[${attr}]}" | wc -l)
        if [ "${t_imm}" -eq 1 ]; then
            case "${attr}" in
                "bin")
                    d_imm=$(echo "${token}" | tr -d 'B' | tr -d 'b')
                    d_imm=$(echo "obase=16; ibase=2; ${d_imm}" | bc)
                    ;;

                "oct")
                    d_imm=$(echo "obase=16; ibase=8; ${d_imm}" | bc)
                    ;;

                "dec1")
                    d_imm=$(echo "obase=16; ibase=10; ${d_imm}" | bc)
                    ;;

                "dec2")
                    d_imm=$(echo "${token}" | tr -d '#')
                    d_imm=$(echo "obase=16; ibase=10; ${d_imm}" | bc)
                    ;;

                "hex2")
                    d_imm=$(echo "${token}" | tr -d 'H')
                    ;;
            esac
            d_imm=$(echo "${d_imm}"   | tr    'X' 'x' | cut -d'x' -f2)
            d_imm=$(printf "0x%8s" "${d_imm}" | tr ' ' '0')
            break
        fi
    done
    echo "${d_imm}"
}

function parse_operator()
{
    token="${1}"
    for attr in bin oct dec1 dec2 hex2; do
        p_data=$(echo "${token}"  | egrep -o "${ITYPE[${attr}]}")
        p_type=$(echo "${token}"  | egrep -o "${ITYPE[${attr}]}" | wc -l)
        if [ "${p_type}" -eq 1 ]; then
            case "${attr}" in
                "+")
					;;
				"-")
					;;
            esac
            p_data=$(echo "${p_data}"   | tr    'X' 'x' | cut -d'x' -f2)
            p_data=$(printf "0x%8s" "${p_data}" | tr ' ' '0')
            break
        fi
    done
    echo "${p_data}"

}

function parse_param()
{
    token="${1}"
	i_data=
	o_data=
	r_data=
    for attr in index deref register immediate; do
        p_data=$(echo "${token}"  | egrep -o "${OTYPE[${attr}]}")
        p_type=$(echo "${token}"  | egrep -o "${OTYPE[${attr}]}" | wc -l)

        if [ "${p_type}" -eq 1 ]; then
			case "${attr}" in
				"index")
					token=$(echo  "${token}" | tr -d '[' | tr -d ']')
					o_data=$(echo "${token}" | egrep -o "${INDEX}")
					reg_t=$(echo  "${token}" | cut -d"${o_data}" -f1)
					r_data=$(parse_reg "${reg_t}")
					imm_t=$(echo  "${token}" | cut -d"${o_data}" -f2)
					i_data=$(parse_imm "${imm_t}")
					#echo "token: ${token}, imm_t: ${imm_t}, i_data: ${i_data}"
					if [ -z "${r_data}" ]; then
						reg_t=$(echo  "${token}" | cut -d"${o_data}" -f2)
						r_data=$(parse_reg "${reg_t}")
						imm_t=$(echo  "${token}" | cut -d"${o_data}" -f1)
						i_data=$(parse_imm "${imm_t}")
					#	echo "i_data: ${i_data}"
						if [ ! "${o_data}" = "+" ]; then # subtraction
							echo "ERROR: malformed operand (R#+Imm)"
							exit 2
						fi
					fi

					if [ ! "${o_data}" = "+" ]; then # subtraction
						o_data="+"
					#	echo "./negate ${i_data}"
						i_data=$(./negate ${i_data})
					fi

					x_data="[${r_data}+${i_data}]"

					if [ -z "${r_data}" ]; then
						echo "ERROR: malformed operand (no register found)!"
						exit 2
					fi

					if [ -z "${i_data}" ]; then
						echo "ERROR: malformed operand (no immediate value found)!"
						exit 2
					fi
					let IMM_TALLY=IMM_TALLY+1
					;;

				"deref")
					d_data="${token}"
					token=$(echo       "${token}" | tr -d '[' | tr -d ']')
					r_data=$(parse_reg "${token}")
					i_data=$(parse_imm "${token}")
					[ ! -z "${r_data}" ] && d_data="[${r_data}]"
					[ ! -z "${i_data}" ] && d_data="[${i_data}]"
					[ ! -z "${i_data}" ] && let IMM_TALLY=IMM_TALLY+1
					;;

				"register")
					r_data=$(parse_reg "${token}")
					;;

				"immediate")
					i_data=$(parse_imm "${token}")
					[ ! -z "${i_data}" ] && let IMM_TALLY=IMM_TALLY+1
					;;
			esac

			#echo "[parse_param] attr:   ${attr}"
			echo "${attr}:${r_data}:${i_data}:${d_data}:${x_data}"
			#[ ! -z "${r_data}" ] && echo "[parse_param] r_data: ${r_data} (register)"
			#[ ! -z "${o_data}" ] && echo "[parse_param] o_data: ${o_data} (index)"
			#[ ! -z "${i_data}" ] && echo "[parse_param] i_data: ${i_data} (immediate)"
            break
        fi
    done
}

read -e line_input

line_input=$(echo  "${line_input}" | tr '[:lower:]' '[:upper:]')

echo "line_input:  ${line_input}"

the_opcode=$(echo   "${line_input}" | egrep -o "${OPCODE}")
#num_operands=$(echo "${line_input}" | egrep -o "${TWO_OPER}" | wc -l)

for ((index=0; index<4; index++)); do
	chk=$(echo "${line_input}" | egrep -o "${PTYPE[${index}]}" | wc -l)
	if [ "${chk}" -eq 1 ]; then
		num_operands="${index}"
		break
	fi
done

if [ "${num_operands}" -eq 3 ]; then
	num_operands=2
fi

echo "the_opcode:     ${the_opcode}"
echo "num_operands:   ${num_operands}"

found_operands=$(echo "${line_input}" | egrep -o "${OPERAND}" | wc -l)
echo "${line_input}" | egrep -o "${OPERAND}"
echo "found_operands: ${found_operands}"

if [ ! "${found_operands}" = "${num_operands}" ]; then
	echo "ERROR: invalid operand for ${the_opcode}"
	exit 1
fi

if [ "${num_operands}" -ge 1 ]; then
	destination=$(echo  "${line_input}" | egrep -o "${OPERAND}"  | head -1)
	#destination=$(echo "${line_input}" | 
	echo
	echo "destination: ${destination}"
	dstresult=$(parse_param "${destination}")

	p_type=$(echo "${dstresult}" | cut -d':' -f1)
	case "${p_type}" in
		"immediate")
			if [ ! "${the_opcode}" = "OUT" ]; then
				echo "ERROR: destination can not be an immediate value!"
				exit 4
			fi
			DSTIMM=$(echo "${dstresult}" | cut -d':' -f3)
			;;

		"register")
			DSTREG=$(echo "${dstresult}" | cut -d':' -f2)
			;;
	esac
	dstresult=$(parse_param "${destination}")
	p_type=$(echo "${dstresult}" | cut -d':' -f1)
	case "${p_type}" in
		"index")
			DSTREG=$(echo "${dstresult}" | cut -d':' -f2)
			DSTIMM=$(echo "${dstresult}" | cut -d':' -f3)
			imm_flag=1
			;;

		"deref")
			echo "DEREF:  $(echo "${dstresult}" | cut -d':' -f4)"
			DSTREG=$(echo "${dstresult}" | cut  -d':' -f2)
			[ -z "${DSTREG}" ] && DSTIMM=$(echo "${dstresult}" | cut -d':' -f3) && imm_flag=1
			;;

		"immediate")
			DSTIMM=$(echo "${dstresult}" | cut -d':' -f3)
			imm_flag=1
			;;

		"register")
			DSTREG=$(echo "${dstresult}" | cut -d':' -f2)
			;;
	esac
fi

if [ "${num_operands}" -eq 2 ]; then
	src=$(echo  "${line_input}"         | egrep -o "${OPERAND}"  | head -2 | tail -1)
	echo
	echo "source: ${src}"
	srcresult=$(parse_param "${src}")
	p_type=$(echo "${srcresult}" | cut -d':' -f1)
	case "${p_type}" in
		"index")
			SRCREG=$(echo "${srcresult}" | cut -d':' -f2)
			SRCIMM=$(echo "${srcresult}" | cut -d':' -f3)
			imm_flag=1
			;;

		"deref")
			echo "DEREF:  $(echo "${srcresult}" | cut -d':' -f4)"
			SRCREG=$(echo "${srcresult}" | cut  -d':' -f2)
			[ -z "${SRCREG}" ] && SRCIMM=$(echo "${srcresult}" | cut -d':' -f3) && imm_flag=1
			;;

		"immediate")
			SRCIMM=$(echo "${srcresult}" | cut -d':' -f3)
			imm_flag=1
			;;

		"register")
			SRCREG=$(echo "${srcresult}" | cut -d':' -f2)
			;;
	esac
fi

echo "IMM_TALLY: ${IMM_TALLY}"
if [ "${IMM_TALLY}" -gt 1 ]; then
	echo "ERROR: Exceeded maximum threshold for immediate values!"
	exit 3
fi

echo "----"
echo "opcode:   ${the_opcode} (0x${opcode[${the_opcode}]})"
echo "imm_flag: ${imm_flag}"
[ ! -z "${DSTREG}" ] && echo "dstreg:   ${DSTREG}" || IMMEDIATE="${DSTIMM}"
[ ! -z "${SRCREG}" ] && echo "srcreg:   ${SRCREG}" || IMMEDIATE="${SRCIMM}"
echo "----"

echo "done"
exit

## TODO: need to check for indexed first, then dereferenced, then register, then immediate
## probably write a function to do this

d_type=$(echo       "${destination}"     | egrep -o "^${REGISTER}$"  | wc -l)

if [ ! "${d_type}" -eq 1 ]; then
    d_type=$(echo   "${destination}"     | egrep -o "^${IMMEDIATE}$" | wc -l)
    if [ ! "${d_type}" -eq 1 ]; then
        d_type=$(echo   "${destination}" | egrep -o "^${INDEX}$"     | wc -l)
        if [ ! "${d_type}" -eq 1 ]; then
            echo "indexed:"
            echo "${destination}" | tr -d '[' | tr -d ']' | egrep -o "${REGISTER}"
            d_type=$(echo "${destination}" | tr -d '[' | tr -d ']' | egrep -o "${REGISTER}" | wc -l)
            if [   "${d_type}" -eq 1 ]; then
                dest_type="dr"
            else
                dest_type="di"
            fi
        else
            dest_type="dx"
        fi
    else
        dest_type="i"
    fi
else
    dest_type="r"
fi    

echo "dest_type: ${dest_type}"


the_source=$(echo   "${line_input}"  | egrep -o "${OPERAND}"     | head -2 | tail -1)

echo "the opcode:  ${the_opcode}"

if [ "${num_operands}" -eq 0 ]; then
    num_operands=$(echo    "${line_input}" | egrep -o "${ONE_OPER}" | wc -l)
    if [ "${num_operands}" -eq 0 ]; then
        num_operands=$(echo    "${line_input}" | egrep -o "${ZEROOPER}" | wc -l)
        if [ "${num_operands}" -eq 0 ]; then
            echo "invalid instruction"
            exit 1
        else
            num_operands="0"
        fi
    else
        num_operands="1"
        echo "destination: ${destination}"
    fi
else
    num_operands="2"
    echo "destination: ${destination}"
    echo "the source:  ${the_source}"
fi
echo "opcode type: ${num_operands} operand instruction"

exit 0
